{
  "name": "simple-mcp",
  "version": "0.3.0",
  "type": "module",
  "description": "Local MCP server with admin panel for managing integrations and agents",
  "bin": {
    "simple-mcp": "./dist/cli.js"
  },
  "scripts": {
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "CLAUDE_MCP_TRANSPORT=sse tsx watch src/cli.ts start",
    "dev:frontend": "vite",
    "build": "pnpm build:backend && pnpm build:frontend",
    "build:backend": "tsup",
    "build:frontend": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@hono/node-server": "^1.13.8",
    "@libsql/client": "^0.14.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.39.3",
    "fast-glob": "^3.3.3",
    "hono": "^4.7.5",
    "mysql2": "^3.20.0",
    "node-html-markdown": "^2.0.0",
    "pg": "^8.20.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@tanstack/react-query": "^5.68.0",
    "@tanstack/react-router": "^1.114.3",
    "@tanstack/router-devtools": "^1.114.3",
    "@tanstack/router-plugin": "^1.114.2",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.30.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "tailwindcss": "^4.0.14",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9",
    "zustand": "^5.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
